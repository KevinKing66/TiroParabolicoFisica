rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Reglas para experimentos
    match /projectile_experiments/{experimentId} {
      allow read: if true;
      allow create: if request.resource.data.initialVelocity is number
        && request.resource.data.initialVelocity >= 0
        && request.resource.data.launchAngleDegrees is number
        && request.resource.data.launchAngleDegrees >= 0
        && request.resource.data.launchAngleDegrees <= 90;
      allow update, delete: if false;
    }

    // Reglas para respuestas académicas
    match /academic_responses/{responseId} {
      allow read: if true;
      allow create: if request.resource.data.type in ['ANALYSIS', 'CHALLENGES']
        && request.resource.data.answers is map;
      allow update, delete: if false;
    }
  }
}
